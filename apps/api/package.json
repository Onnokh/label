  "license": "UNLICENSED",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.1",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@effect/language-service": "^0.85.1",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
