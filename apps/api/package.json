{
  "name": "@label/api",
  "version": "0.0.0",
  "description": "Label backend API.",
  "type": "module",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:push": "node -e \"require('node:fs').mkdirSync('./data', { recursive: true })\" && drizzle-kit push",
    "dev": "tsx watch src/index.ts",
    "prepare": "effect-language-service patch",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
