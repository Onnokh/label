DATABASE_URL=postgres://label:label@localhost:5434/label
PORT=3002

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BETTER_AUTH_SECRET=
# Google OAuth accepts localhost redirects, but rejects .localhost subdomains.
# When running `pnpm --filter @label/api dev`, portless exposes the API on
# https://api.label.localhost while the Bun app listens on localhost:4001.
BETTER_AUTH_URL=http://localhost:4001
BETTER_AUTH_TRUSTED_ORIGINS=https://web.label.localhost

FETCH_TIMEOUT_MS=5000
FETCH_USER_AGENT=saved-items/1.0 (+https://localhost/SavedItems)
FETCH_BROWSER_FALLBACK_ENABLED=true
FETCH_BROWSER_TIMEOUT_MS=15000
FETCH_BROWSER_HEADLESS=true

AI_ENABLED=false
AI_PROVIDER=
AI_MODEL=
